<+>name: Qodana Analysis\n\non:\n  workflow_call:\n  workflow_dispatch:\n  schedule:\n    - cron: '0 0 * * *'\n\njobs:\n  qodana:\n    name: Run Qodana Analysis\n    runs-on: ubuntu-latest\n    \n    steps:\n      - name: Checkout code\n        uses: actions/checkout@v4\n        with:\n          fetch-depth: 0\n          \n      - name: Set up JDK 17\n        uses: actions/setup-java@v3\n        with:\n          java-version: '17'\n          distribution: 'temurin'\n          \n      # Cache Maven packages for faster builds\n      - name: Cache Maven packages\n        uses: actions/cache@v3\n        with:\n          path: ~/.m2/repository\n          key: ${{ runner.os }}-maven-${{ hashFiles('**/pom.xml') }}\n          \n      # Cache Qodana results for faster subsequent runs\n      - name: Cache Qodana results\n        uses: actions/cache@v3\n        with:\n          path: ${{ github.workspace }}/.qodana/cache\n          key: qodana-cache-${{ hashFiles('**/pom.xml') }}\n          \n      # Create Qodana configuration if it doesn't exist\n      - name: Setup Qodana config\n        run: |\n          mkdir -p .qodana\n          if [ ! -f .qodana/qodana.yaml ]; then\n            echo 'version: \"1.0\"\n        ide: QDJVMC\n        linter: jetbrains/qodana-jvm-community:latest' > .qodana/qodana.yaml\n          fi\n          \n      # Run Qodana analysis using community edition\n      - name: Run Qodana\n        uses: JetBrains/qodana-action@v4\n        with:\n          linter: jetbrains/qodana-jvm-community:latest\n          project-dir: clinic-api\n          fail-total-problems: true\n          args: --show-report --save-report\n          \n      # Upload the Qodana report\n      - name: Upload Qodana report\n        if: always()\n        uses: actions/upload-artifact@v4\n        with:\n          name: qodana-report\n          path: ${{ github.workspace }}/.qodana/report/\n          retention-days: 7\n\n      - name: Comment on PR\n        if: github.event_name == 'pull_request' && failure()\n        uses: actions/github-script@v7\n        with:\n          script: |\n            const fs = require('fs');\n            try {\n              const report = fs.readFileSync('${{ github.workspace }}/.qodana/log/ci.log', 'utf8');\n              const maxGitHubBodyLength = 65536;\n              const reportPreview = report.length > maxGitHubBodyLength\n                ? report.substring(0, maxGitHubBodyLength) + '\\n... Report was truncated'\n                : report;\n              await github.issues.createComment({\n                issue_number: context.issue.number,\n                owner: context.repo.owner,\n                repo: context.repo.repo,\n                body: '### Qodana found some issues\\n\\n```\\n' + reportPreview + '\\n```\\n\\n[Full Qodana Report](${{ github.server_url }}/${{ github.repository }}/actions/runs/${{ github.run_id }}#summary)'\n              });\n            } catch (error) {\n              console.error('Error creating PR comment:', error);\n            }\n
