{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["vitest", "@testing-library/jest-dom"],
    "typeRoots": [
      "./node_modules/@types",
      "./tests"
    ]
  },
  "include": [
    "**/*.test.ts",
